# --- Tana Configuration ---
# Get this from Tana > Settings > Developers > API Token
TANA_TOKEN=your_tana_token_here

# Default local bridge URL (Tana Desktop)
TANA_URL=http://127.0.0.1:8262/mcp

# --- AI Configuration ---
# Path to your Gemini CLI executable (e.g., /usr/local/bin/gemini)
# Use 'which gemini' to find yours
GEMINI_PATH=gemini

# --- Model Preferences ---
# Default model to use (gemini-2.0-flash, gemini-1.5-pro, etc.)
DEFAULT_MODEL=gemini-2.0-flash
